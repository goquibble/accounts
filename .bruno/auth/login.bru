meta {
  name: login
  type: http
  seq: 2
}

post {
  url: http://localhost:8000/api/v1/auth/login
  body: formUrlEncoded
  auth: inherit
}

body:form-urlencoded {
  username: admin@admin.com
  password: adminpass
}

script:post-response {
  let data = res.body;
  bru.setVar("token", data.access_token);
}

settings {
  encodeUrl: true
  timeout: 0
}
